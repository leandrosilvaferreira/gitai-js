{
  "name": "@notyped/gitai",
  "version": "1.6.0",
  "description": "AI-powered git commit assistant and release note generator",
  "main": "dist/index.js",
  "bin": {
    "gitai": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "node dist/index.js",
    "build": "npm run lint && tsup",
    "dev": "tsup --watch",
    "lint": "eslint 'src/**/*.{ts,js}' 'scripts/**/*.ts' && tsc --noEmit && tsc -p tsconfig.scripts.json",
    "format": "prettier --write 'src/**/*.{ts,js}'",
    "release-notes": "npm run lint && tsx src/releaser.ts",
    "release": "npm test && npm run build && tsx scripts/release-flow.ts",
    "release:status": "tsx scripts/release-flow.ts --status",
    "test": "node --import tsx --test \"src/**/*.test.ts\" \"scripts/**/*.test.ts\"",
    "test:coverage": "c8 --all --src src --exclude \"src/**/*.test.ts\" --exclude src/index.ts --exclude src/version.ts --exclude src/utils/logger.ts --exclude src/releaser.ts --reporter=text --reporter=html --check-coverage --lines 80 --branches 65 --functions 80 --statements 80 npm test"
  },
  "keywords": [
    "git",
    "ai",
    "commit",
    "assistant"
  ],
  "author": "Leandro Silva Ferreira",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/leandrosilvaferreira/gitai-js"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^22.0.0",
    "@types/update-notifier": "^6.0.8",
    "c8": "^12.0.0",
    "eslint": "^9.0.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-sonarjs": "^4.2.0",
    "globals": "^17.2.0",
    "prettier": "^3.0.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.64.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@types/semver": "^7.7.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "execa": "^9.5.2",
    "groq-sdk": "^1.3.0",
    "inquirer": "^12.4.1",
    "openai": "^6.44.0",
    "semver": "^7.7.3",
    "update-notifier": "^7.3.1"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  }
}
